{
  "name": "VibeRadar",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "cd android && ./gradlew clean && cd ../ios && xcodebuild clean",
    "pod-install": "cd ios && pod install"
  },
  "dependencies": {
    "@nozbe/watermelondb": "^0.26.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@reduxjs/toolkit": "^2.4.0",
    "react": "18.3.1",
    "react-native": "0.76.6",
    "react-native-ble-plx": "^3.2.0",
    "react-native-compass-heading": "^2.0.2",
    "react-native-safe-area-context": "^5.0.0",
    "react-native-screens": "4.19.0",
    "react-native-sensors": "^7.3.5",
    "react-native-svg": "^15.8.0",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "0.76.6",
    "@react-native/eslint-config": "0.76.6",
    "@react-native/metro-config": "0.76.6",
    "@react-native/typescript-config": "0.76.6",
    "@testing-library/react-native": "^12.8.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "@types/uuid": "^10.0.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "react-test-renderer": "18.3.1",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-ble-plx|react-native-sensors|react-native-svg|react-native-compass-heading|@nozbe/watermelondb|@react-native-async-storage)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
